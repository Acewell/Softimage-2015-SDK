<?xml version="1.0" encoding="Windows-1252"?>
<VisualStudioPropertySheet
	ProjectType="Visual C++"
	Version="8.00"
	Name="link-debug"
	>
	<Tool
		Name="VCLinkerTool"
		LinkIncremental="2"
		GenerateManifest="true"
		ManifestFile="$(IntDir)\$(TargetFileName).intermediate.manifest"
		GenerateDebugInformation="true"
	/>
	<UserMacro
		Name="DebugSuffix"
		Value="d"
	/>
	<UserMacro
		Name="DebugDotSuffix"
		Value=".d"
	/>
</VisualStudioPropertySheet>
